# =============================================================================
# Neo4j connection
#
# RECOMMENDED: use Neo4j Aura (hosted, free tier).
#   1. Sign up at https://console.neo4j.io
#   2. Create a new "AuraDB Free" instance (Aura ships an empty database, region
#      doesn't matter for the demo).
#   3. Download the credentials file it gives you ONCE - it contains
#      NEO4J_URI, NEO4J_USERNAME, NEO4J_PASSWORD.
#   4. Paste them below. The URI scheme will be `neo4j+s://...` for Aura.
#
# FALLBACK: run Neo4j locally via `docker compose up -d` and use the values in
# the "Local docker-compose" block below.
# =============================================================================

# --- Aura (hosted) -----------------------------------------------------------
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-aura-generated-password
NEO4J_DATABASE=neo4j

# --- Local docker-compose (uncomment + comment-out the Aura block above) -----
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=knowledgeagent
# NEO4J_DATABASE=neo4j

# =============================================================================
# OpenRouter (https://openrouter.ai) - used as an OpenAI-compatible endpoint.
# Create a key at https://openrouter.ai/keys and paste it below.
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Pinning the model in env keeps swapping providers a one-line change.
OPENROUTER_MODEL=openai/gpt-5.5
# Optional, but OpenRouter recommends sending these for analytics.
OPENROUTER_APP_NAME=knowledge-agent-example
OPENROUTER_HTTP_REFERER=http://localhost

# =============================================================================
# Provenance / filestore
# Local folder simulating an S3 bucket - each ingested payload is written
# verbatim here and referenced from the graph (PROV-O wasDerivedFrom).
# =============================================================================
FILESTORE_DIR=./filestore
# Logical bucket name we use in prov URIs. Swap to s3://my-bucket later.
FILESTORE_BUCKET=local-prov-store

# =============================================================================
# Agent behaviour toggles
# =============================================================================
# When true, schema-evolution proposals require a human y/n before being
# applied to the graph. CLI path prompts on stdin, chat path uses LangGraph
# `interrupt()`. Set to false in the demo to keep things flowing.
SCHEMA_EVOLUTION_REQUIRE_APPROVAL=true
# How chatty the agent is in the terminal (0 = quiet, 1 = normal, 2 = debug).
AGENT_VERBOSITY=1
# Cache the Neo4j schema for this many seconds (invalidated on evolution).
SCHEMA_CACHE_TTL_SECONDS=30
# Auto-retries on 429 / 5xx from the LLM gateway.
LLM_MAX_RETRIES=3
# Default completion-length cap (chat / ask). 1024 fits inside OpenRouter
# free-tier per-request limits.
LLM_MAX_TOKENS=1024
# Separate cap for the structured-output prompts in the schema-evolution
# flow (proposal + per-payload extraction). They emit larger JSON so 1024
# truncates them. 8192 is comfortable; raise for more for heavier payloads.
LLM_MAX_TOKENS_STRUCTURED=8192
